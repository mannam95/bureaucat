APP_ENV=dev                 # 'dev' disables password validation
DATABASE_URL=postgres://bureaucat:bureaucat@postgres:5432/bureaucat?sslmode=disable
JWT_SECRET=your-secure-random-secret-at-least-32-characters
# ACCESS_TOKEN_EXPIRY_MINS=5       # minutes (default: 5)
# REFRESH_TOKEN_EXPIRY_DAYS=7      # days (default: 7)
DEMO_USER_EMAIL="demo@gmail.com"
DEMO_USER_PASSWORD="Passw0rd!"

S3_ENDPOINT=http://garage:3900
FILES_BUCKET_NAME=bureaucat
FILES_BUCKET_ACCESS_KEY_ID=your-bucket-name-from-s3
FILES_BUCKET_SECRET_ACCESS_KEY=your-bucket-secret-from-s3
# SigV4 signing region. Leave unset for the local Garage stack, which ignores it.
# Against real AWS S3 this MUST match the bucket's region, or every request fails
# with SignatureDoesNotMatch. Example: FILES_BUCKET_REGION=eu-central-1
# FILES_BUCKET_REGION=

# Email notifications (optional). Set SMTP_HOST, SMTP_PORT and SMTP_FROM to
# enable; leave them blank to disable email. SMTP_USER/SMTP_PASS are optional
# for unauthenticated relays (e.g. a local Mailpit on 1025). Port 465 uses
# implicit TLS; other ports use STARTTLS when available.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=Bureaucat <no-reply@example.com>

